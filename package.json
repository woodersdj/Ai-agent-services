{
  "name": "ai-agent-services",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "register:loomal": "ts-node scripts/register-loomal.ts",
    "deploy:railway": "npm run build && ./deploy.sh railway",
    "deploy:flyio": "npm run build && ./deploy.sh flyio",
    "deploy:render": "npm run build && ./deploy.sh render",
    "deploy:vercel": "npm run build && ./deploy.sh vercel"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@x402/express": "^1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "zod": "^3.21.4",
    "node-fetch": "^3.4.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.0.0",
    "vitest": "^1.0.0"
  }
}
